NOTION_API_KEY=secret_your_notion_integration_token_here

# Required for MSP task imports
NOTION_TASKS_DB_ID=

# Optional: used to auto-link each task to the Ametek project row
NOTION_PROJECTS_DB_ID=
NOTION_AMETEK_PROJECT_PAGE_ID=

# Optional: Team Member(s) database ID (auto-discovered by title if omitted)
NOTION_TEAM_MEMBERS_DB_ID=

# Notes field overwrite policy: msp | notion
NOTES_OWNER=notion

# Risks dashboard IDs (optional, for setup script tracking)
NOTION_RISKS_DB_ID=
NOTION_DASHBOARD_PAGE_ID=
NOTION_PROJECT_STATUS_PAGE_ID=
